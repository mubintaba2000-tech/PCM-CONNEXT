rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() { return request.auth != null; }
    // In a real environment, you'd use custom claims. For this demo we'll allow all logged-in users 
    // to act as all roles since we are simulating login via signInAnonymously.
    // function role() { return request.auth.token.role; }
    function isSales()    { return true; } // role() == 'sales';
    function isEngineer() { return true; } // role() == 'engineer';
    function isOwner()    { return true; } // role() == 'owner';
    function isAdmin()    { return true; } // role() == 'admin';

    match /projects/{id} {
      allow read:  if isLoggedIn();
      allow write: if isEngineer() || isOwner();
    }
    match /customers/{id} {
      allow read:  if isLoggedIn();
      allow write: if isSales() || isOwner() || isAdmin();
    }
    match /warranties/{id} {
      allow read:  if isLoggedIn();
      allow write: if isSales() || isOwner() || isAdmin();
    }
    match /projectDocuments/{id} {
      // Documents can be added/read by logged in users
      allow read, write: if isLoggedIn();
    }
  }
}
